{
  "priority": 100,
  "request": {
    "method": "POST",
    "urlPath": "/auth/v1/oauth2/token",
    "queryParameters": {
      "grant_type": {
        "equalTo": "client_credentials"
      },
      "scope": {
        "equalTo": "innreach_tp"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "bodyFileName": "oauth/d2ir-oauth-token-response.json"
  }
}
